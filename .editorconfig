# =========================================================================================== #
# EditorConfig — https://editorconfig.org                                                     #
# Ensures consistent coding style across editors and IDEs.                                    #
# =========================================================================================== #

root = true

[*]
charset                  = utf-8
end_of_line              = lf
indent_size              = 2
indent_style             = space
insert_final_newline     = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
max_line_length          = off

[Makefile]
indent_style = tab
