# =========================================================================================== #
# .gitattributes — Line ending and diff driver configuration.                                 #
# =========================================================================================== #

# Default: enforce LF for all text files
* text=auto eol=lf

# HCL / Terraform
*.tf    text eol=lf diff=terraform
*.tfvars text eol=lf diff=terraform

# YAML
*.yml  text eol=lf diff=yaml
*.yaml text eol=lf diff=yaml

# Markdown
*.md text eol=lf diff=markdown

# Shell
*.sh text eol=lf

# JSON
*.json text eol=lf

# Tell GitHub this is primarily an HCL repository
*.tf     linguist-language=HCL
*.tfvars linguist-language=HCL

# Exclude tooling files from release archives
.editorconfig    export-ignore
.gitattributes   export-ignore
.gitignore       export-ignore
.pre-commit-config.yaml export-ignore
.config/         export-ignore
.vscode/         export-ignore
